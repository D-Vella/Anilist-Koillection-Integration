# Copy this file to .env and fill in your own values. .env is git-ignored.

# --- Koillection ---------------------------------------------------------

# Base URL of your Koillection instance (no trailing slash, no /api suffix)
KOILLECTION_BASE_URL=http://192.168.1.50:8080

# Credentials for a Koillection user account
KOILLECTION_USERNAME=your-username
KOILLECTION_PASSWORD=your-password

# Name (or UUID) of the Koillection collection to sync, e.g. "Manga"
KOILLECTION_COLLECTION=Manga

# Label of the custom field used to store the AniList description on each item
KOILLECTION_DESCRIPTION_LABEL=Description

# --- AniList ---------------------------------------------------------------

# AniList GraphQL endpoint (rarely needs changing)
ANILIST_API_URL=https://graphql.anilist.co

# Seconds to wait between AniList requests to stay within its rate limit
ANILIST_REQUEST_DELAY=2.0

# --- Behaviour ---------------------------------------------------------------

# Set to "true" to overwrite items that already have an image/description
OVERWRITE_EXISTING=false

# Set to "true" to log what would change without writing anything
DRY_RUN=false

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15
